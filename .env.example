# Kage Environment Variables
# Copy this file to .env and configure as needed

# OpenAI Configuration (if using OpenAI provider)
OPENAI_API_KEY=sk-your-api-key-here

# Ollama Configuration (if using Ollama provider)
OLLAMA_BASE_URL=http://localhost:11434

# LM Studio Configuration (if using LM Studio provider)
LMSTUDIO_BASE_URL=http://localhost:1234

# Logging
KAGE_LOG_LEVEL=INFO

# Session Directory (optional override)
# KAGE_SESSION_DIR=~/.local/share/kage/sessions

# Config Directory (optional override)
# KAGE_CONFIG_DIR=~/.config/kage
